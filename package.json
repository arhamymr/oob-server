{
  "name": "oob-server",
  "version": "1.0.0",
  "description": "Zero-dependency OOB (out-of-band) listener server for HTTP and DNS interaction logging",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "vps-setup": "chmod +x ./setup.sh && sudo ./setup.sh",
    "pm2-start": "pm2 start server.js --name 'oob-server'",
    "pm2-logs": "pm2 logs oob-server"
  },
  "keywords": [
    "oob",
    "collaborator",
    "dns",
    "http",
    "security"
  ],
